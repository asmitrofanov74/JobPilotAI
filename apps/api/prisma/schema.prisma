generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  SAVED
  APPLIED
  PHONE_SCREEN
  TECHNICAL
  ONSITE
  OFFER
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum InterviewType {
  PHONE
  TECHNICAL
  BEHAVIORAL
  SYSTEM_DESIGN
  CODING
  ONSITE
  PANEL
  TAKE_HOME
}

enum QuestionType {
  TECHNICAL
  BEHAVIORAL
  SYSTEM_DESIGN
  CODING
}

enum SubscriptionTier {
  FREE
  PRO
}

enum ApplicationSource {
  MANUAL
  LINKEDIN
  INDEED
  GLASSDOOR
  COMPANY_SITE
  REFERRAL
  OTHER
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  firstName      String
  lastName       String
  title          String?
  targetRole     String?
  experienceLevel String?
  targetLocations String?
  summary        String?
  avatarUrl      String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  jobApplications JobApplication[]
  resumes         Resume[]
  coverLetters    CoverLetter[]
  interviewQuestions InterviewQuestion[]
  subscription    Subscription?
  skillGapReports SkillGapReport[]

  @@index([email])
  @@map("users")
}

model Subscription {
  id        String           @id @default(cuid())
  tier      SubscriptionTier @default(FREE)
  stripeCustomerId String?
  stripeSubscriptionId String?
  currentPeriodStart DateTime?
  currentPeriodEnd DateTime?
  canceledAt DateTime?
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("subscriptions")
}

model JobApplication {
  id             String          @id @default(cuid())
  companyName    String
  companyWebsite String?
  companyLogo    String?
  jobTitle       String
  jobUrl         String?
  jobDescription String?
  location       String?
  salaryRange    String?
  salaryMin      Int?
  salaryMax      Int?
  currency       String          @default("CAD")
  employmentType String?         // Full-time, Contract, Part-time
  workMode       String?         // Remote, Hybrid, On-site
  status         JobStatus       @default(SAVED)
  source         ApplicationSource @default(MANUAL)
  sourceUrl      String?           // URL the job was scraped from
  sourceId       String?           // External ID from the source (e.g. LinkedIn job ID)
  scrapedAt      DateTime?         // When this job was scraped
  notes          String?
  appliedAt      DateTime?
  rejectedAt     DateTime?
  rejectionReason String?
  offerSalary    Int?
  offerEquity    String?
  offerBenefits  String?
  offerDeadline  DateTime?
  offerAcceptedAt DateTime?
  rating         Int?            // 1-5
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  interviews     Interview[]
  events         ApplicationEvent[]

  @@index([userId, status])
  @@index([userId, companyName])
  @@index([userId, createdAt])
  @@map("job_applications")
}

model Interview {
  id              String        @id @default(cuid())
  type            InterviewType
  round           Int           @default(1)
  scheduledAt     DateTime?
  durationMinutes Int?
  interviewers    String?       // JSON array of names
  location        String?       // Physical address or video link
  notes           String?
  feedback        String?
  rating          Int?          // 1-5
  isCompleted     Boolean       @default(false)
  jobApplicationId String
  jobApplication  JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([jobApplicationId])
  @@map("interviews")
}

model ApplicationEvent {
  id              String        @id @default(cuid())
  eventType       String        // status_change, interview_scheduled, note_added, etc.
  description     String?
  metadata        Json?         // Flexible metadata
  jobApplicationId String
  jobApplication  JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@index([jobApplicationId])
  @@index([createdAt])
  @@map("application_events")
}

model Resume {
  id          String   @id @default(cuid())
  title       String
  fileUrl     String
  fileKey     String   // S3 key
  fileSize    Int?
  mimeType    String?
  isPrimary   Boolean  @default(false)
  parsedSkills String? // JSON array of parsed skills
  parsedExperience String? // JSON parsed experience
  parsedEducation String? // JSON parsed education
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("resumes")
}

model CoverLetter {
  id          String   @id @default(cuid())
  jobTitle    String
  companyName String
  content     String
  tone        String   @default("professional")
  jobDescription String?
  isGenerated Boolean  @default(true)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("cover_letters")
}

model InterviewQuestion {
  id          String       @id @default(cuid())
  question    String
  answer      String?
  type        QuestionType
  category    String?      // e.g., "Arrays", "System Design", "Leadership"
  difficulty  Int?         // 1-5
  source      String?      // "ai", "manual", "community"
  isFavorite  Boolean      @default(false)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, type])
  @@map("interview_questions")
}

model SkillGapReport {
  id              String   @id @default(cuid())
  jobDescription  String
  jobTitle        String
  companyName     String
  requiredSkills  Json     // JSON: { skill: string, importance: string }[]
  userSkills      Json     // JSON: string[]
  missingSkills   Json     // JSON: { skill: string, importance: string, recommendation: string }[]
  matchScore      Float    // 0-100
  recommendations Json?    // JSON: string[]
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([userId])
  @@map("skill_gap_reports")
}

model MarketSkill {
  id        String   @id @default(cuid())
  skill     String
  count     Int      @default(0)
  month     String   // "2026-01"
  role      String?  // Software Engineer, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([skill, month, role])
  @@index([month])
  @@index([skill])
  @@map("market_skills")
}

model SalaryData {
  id        String   @id @default(cuid())
  role      String
  location  String?
  experienceLevel String?
  salaryMin Int
  salaryMax Int
  salaryAvg Int
  currency  String   @default("CAD")
  source    String   @default("job_posting")
  month     String
  createdAt DateTime @default(now())

  @@index([role, location])
  @@index([month])
  @@map("salary_data")
}
